#!/usr/bin/env sh
set -eu

PROG="nekoagent"
INSTALL_DIR_DEFAULT="${HOME}/.local/bin"
INSTALL_DIR="${NEKO_INSTALL_DIR:-$INSTALL_DIR_DEFAULT}"
AGENT_BIN="${NEKO_AGENT_BIN:-$INSTALL_DIR/neko-agent}"
CONFIG_DIR="${NEKO_AGENT_CONFIG_DIR:-/etc/neko-agent}"
STATE_DIR="${NEKO_AGENT_STATE_DIR:-/var/run/neko-agent}"
AGENT_REPO="${NEKO_AGENT_REPO:-foru17/neko-master}"
VERSION="0.2.4"

log() {
  printf '[%s] %s\n' "$PROG" "$1"
}

err() {
  printf '[%s] error: %s\n' "$PROG" "$1" >&2
}

ensure_dirs() {
  mkdir -p "$CONFIG_DIR" "$STATE_DIR"
}

config_file() {
  name="$1"
  printf '%s/%s.env\n' "$CONFIG_DIR" "$name"
}

pid_file() {
  name="$1"
  printf '%s/%s.pid\n' "$STATE_DIR" "$name"
}

log_file() {
  name="$1"
  printf '%s/%s.log\n' "$STATE_DIR" "$name"
}

is_running() {
  name="$1"
  # When a service manager owns this instance, the pidfile is never written
  # (cmd_start delegates to systemctl/launchctl/init.d). Ask the service
  # manager directly so list/status/restart-all/upgrade reflect reality.
  if is_service_managed "$name"; then
    manager="$(detect_service_manager)"
    service="$(service_name_for_instance "$name")"
    case "$manager" in
      systemd)
        systemctl is-active --quiet "$service"
        return $?
        ;;
      launchd)
        label="io.neko-master.agent.${name}"
        if launchctl list 2>/dev/null | awk -v lbl="$label" 'NR>1 && $3==lbl {found=1} END {exit !found}'; then
          return 0
        fi
        return 1
        ;;
      openwrt)
        init_path="/etc/init.d/${service}"
        if [ -x "$init_path" ]; then
          "$init_path" status >/dev/null 2>&1
          return $?
        fi
        ;;
    esac
  fi
  pf="$(pid_file "$name")"
  if [ ! -f "$pf" ]; then
    return 1
  fi
  pid="$(cat "$pf" 2>/dev/null || true)"
  if [ -z "$pid" ]; then
    return 1
  fi
  kill -0 "$pid" >/dev/null 2>&1
}

# ── Download helpers ────────────────────────────────────────────────────────

download_file() {
  url="$1"
  output="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url" -o "$output"
    return 0
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -qO "$output" "$url"
    return 0
  fi
  err "curl or wget is required"
  exit 1
}

compute_sha256() {
  file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | awk '{print $1}'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | awk '{print $1}'
    return 0
  fi
  if command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 "$file" | awk '{print $2}'
    return 0
  fi
  echo ""
}

normalize_os() {
  raw="$(uname -s | tr 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' 'abcdefghijklmnopqrstuvwxyz')"
  case "$raw" in
    linux)  echo "linux" ;;
    darwin) echo "darwin" ;;
    *)
      err "unsupported OS: $raw"
      exit 1
      ;;
  esac
}

normalize_arch() {
  raw="$(uname -m | tr 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' 'abcdefghijklmnopqrstuvwxyz')"
  case "$raw" in
    x86_64|amd64)       echo "amd64" ;;
    aarch64|arm64)      echo "arm64" ;;
    armv7l|armv7|armhf) echo "armv7" ;;
    mips)               echo "mips" ;;
    mipsle)             echo "mipsle" ;;
    *)
      err "unsupported architecture: $raw"
      exit 1
      ;;
  esac
}

detect_service_manager() {
  os="$(normalize_os)"
  if [ "$os" = "linux" ] && [ -f "/etc/openwrt_release" ] && [ -f "/etc/rc.common" ]; then
    echo "openwrt"
    return 0
  fi

  if [ "$os" = "linux" ] && command -v systemctl >/dev/null 2>&1 && [ -d "/etc/systemd/system" ]; then
    echo "systemd"
    return 0
  fi

  if [ "$os" = "darwin" ] && command -v launchctl >/dev/null 2>&1; then
    echo "launchd"
    return 0
  fi

  if command -v crontab >/dev/null 2>&1; then
    echo "cron"
    return 0
  fi

  echo "none"
}

service_name_for_instance() {
  name="$1"
  printf 'neko-agent-%s\n' "$name"
}

# Check if instance is managed by a service manager (systemd/launchd/openwrt)
# Returns 0 if managed, 1 if not
is_service_managed() {
  name="$1"
  manager="$(detect_service_manager)"
  service="$(service_name_for_instance "$name")"
  case "$manager" in
    systemd)
      systemctl is-enabled "$service" >/dev/null 2>&1 && return 0
      ;;
    launchd)
      label="io.neko-master.agent.${name}"
      plist_path="${HOME}/Library/LaunchAgents/${label}.plist"
      [ -f "$plist_path" ] && return 0
      ;;
    openwrt)
      init_path="/etc/init.d/${service}"
      [ -x "$init_path" ] && return 0
      ;;
  esac
  return 1
}

runner_file() {
  name="$1"
  printf '%s/%s.run.sh\n' "$CONFIG_DIR" "$name"
}

require_linux_root() {
  manager="$1"
  if [ "$manager" = "systemd" ] || [ "$manager" = "openwrt" ]; then
    if [ "$(id -u)" -ne 0 ]; then
      err "$manager autostart requires root privileges"
      exit 1
    fi
  fi
}

generate_runner_script() {
  name="$1"
  rf="$(runner_file "$name")"
  cf="$(config_file "$name")"
  ensure_dirs

  cat > "$rf" <<EOF
#!/usr/bin/env sh
set -eu

AGENT_BIN='$AGENT_BIN'
CONF='$cf'

[ -f "\$CONF" ] || {
  echo "[nekoagent] error: config not found: \$CONF" >&2
  exit 1
}

. "\$CONF"

: "\${NEKO_SERVER:?missing NEKO_SERVER}"
: "\${NEKO_BACKEND_ID:?missing NEKO_BACKEND_ID}"
: "\${NEKO_BACKEND_TOKEN:?missing NEKO_BACKEND_TOKEN}"
: "\${NEKO_GATEWAY_TYPE:?missing NEKO_GATEWAY_TYPE}"
: "\${NEKO_GATEWAY_URL:?missing NEKO_GATEWAY_URL}"

set -- "\$AGENT_BIN" \
  --server-url "\$NEKO_SERVER" \
  --backend-id "\$NEKO_BACKEND_ID" \
  --backend-token "\$NEKO_BACKEND_TOKEN" \
  --gateway-type "\$NEKO_GATEWAY_TYPE" \
  --gateway-url "\$NEKO_GATEWAY_URL"

[ -n "\${NEKO_GATEWAY_TOKEN:-}" ] && set -- "\$@" --gateway-token "\$NEKO_GATEWAY_TOKEN"
[ -n "\${NEKO_AGENT_ID:-}" ] && set -- "\$@" --agent-id "\$NEKO_AGENT_ID"
[ -n "\${NEKO_REPORT_INTERVAL:-}" ] && set -- "\$@" --report-interval "\$NEKO_REPORT_INTERVAL"
[ -n "\${NEKO_HEARTBEAT_INTERVAL:-}" ] && set -- "\$@" --heartbeat-interval "\$NEKO_HEARTBEAT_INTERVAL"
[ -n "\${NEKO_GATEWAY_POLL_INTERVAL:-}" ] && set -- "\$@" --gateway-poll-interval "\$NEKO_GATEWAY_POLL_INTERVAL"
[ -n "\${NEKO_REQUEST_TIMEOUT:-}" ] && set -- "\$@" --request-timeout "\$NEKO_REQUEST_TIMEOUT"
[ -n "\${NEKO_REPORT_BATCH_SIZE:-}" ] && set -- "\$@" --report-batch-size "\$NEKO_REPORT_BATCH_SIZE"
[ -n "\${NEKO_MAX_PENDING_UPDATES:-}" ] && set -- "\$@" --max-pending-updates "\$NEKO_MAX_PENDING_UPDATES"
[ -n "\${NEKO_STALE_FLOW_TIMEOUT:-}" ] && set -- "\$@" --stale-flow-timeout "\$NEKO_STALE_FLOW_TIMEOUT"

set -- "\$@" --log="\${NEKO_LOG:-true}"
exec "\$@"
EOF

  chmod +x "$rf"
  printf '%s\n' "$rf"
}

write_systemd_unit() {
  name="$1"
  runner="$2"
  service="$(service_name_for_instance "$name")"
  unit_path="/etc/systemd/system/${service}.service"
  cat > "$unit_path" <<EOF
[Unit]
Description=Neko Agent (${name})
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${runner}
Restart=always
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=10
LimitNOFILE=65536
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
EOF
  printf '%s\n' "$unit_path"
}

write_openwrt_init() {
  name="$1"
  runner="$2"
  service="$(service_name_for_instance "$name")"
  init_path="/etc/init.d/${service}"
  cat > "$init_path" <<EOF
#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

start_service() {
  procd_open_instance
  procd_set_param command "${runner}"
  procd_set_param respawn 3600 5 5
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}
EOF
  chmod +x "$init_path"
  printf '%s\n' "$init_path"
}

write_launchd_plist() {
  name="$1"
  runner="$2"
  launch_dir="${HOME}/Library/LaunchAgents"
  label="io.neko-master.agent.${name}"
  plist_path="${launch_dir}/${label}.plist"
  mkdir -p "$launch_dir"
  cat > "$plist_path" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${label}</string>

  <key>ProgramArguments</key>
  <array>
    <string>${runner}</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>$(log_file "$name")</string>
  <key>StandardErrorPath</key>
  <string>$(log_file "$name")</string>
</dict>
</plist>
EOF
  printf '%s\n' "$plist_path"
}

enable_autostart_systemd() {
  name="$1"
  runner="$2"
  service="$(service_name_for_instance "$name")"
  write_systemd_unit "$name" "$runner" >/dev/null
  systemctl daemon-reload
  systemctl enable "$service" >/dev/null
  systemctl restart "$service"
}

enable_autostart_openwrt() {
  name="$1"
  runner="$2"
  service="$(service_name_for_instance "$name")"
  init_path="$(write_openwrt_init "$name" "$runner")"
  "$init_path" enable
  "$init_path" restart
}

enable_autostart_launchd() {
  name="$1"
  runner="$2"
  plist_path="$(write_launchd_plist "$name" "$runner")"
  launchctl unload "$plist_path" >/dev/null 2>&1 || true
  launchctl load "$plist_path"
}

enable_autostart_cron() {
  name="$1"
  runner="$2"
  marker="# nekoagent-autostart-${name}"
  line="@reboot ${runner} >/dev/null 2>&1 ${marker}"
  old_cron="$(crontab -l 2>/dev/null || true)"
  {
    printf '%s\n' "$old_cron" | grep -v "$marker" || true
    printf '%s\n' "$line"
  } | crontab -
}

disable_autostart_systemd() {
  name="$1"
  service="$(service_name_for_instance "$name")"
  unit_path="/etc/systemd/system/${service}.service"
  systemctl disable "$service" >/dev/null 2>&1 || true
  systemctl stop "$service" >/dev/null 2>&1 || true
  rm -f "$unit_path"
  systemctl daemon-reload >/dev/null 2>&1 || true
}

disable_autostart_openwrt() {
  name="$1"
  service="$(service_name_for_instance "$name")"
  init_path="/etc/init.d/${service}"
  if [ -x "$init_path" ]; then
    "$init_path" disable >/dev/null 2>&1 || true
    "$init_path" stop >/dev/null 2>&1 || true
  fi
  rm -f "$init_path"
}

disable_autostart_launchd() {
  name="$1"
  label="io.neko-master.agent.${name}"
  plist_path="${HOME}/Library/LaunchAgents/${label}.plist"
  launchctl unload "$plist_path" >/dev/null 2>&1 || true
  rm -f "$plist_path"
}

disable_autostart_cron() {
  name="$1"
  marker="# nekoagent-autostart-${name}"
  old_cron="$(crontab -l 2>/dev/null || true)"
  printf '%s\n' "$old_cron" | grep -v "$marker" | crontab -
}

cmd_enable_autostart() {
  name="$1"
  ensure_dirs
  load_config "$name"
  runner="$(generate_runner_script "$name")"
  manager="$(detect_service_manager)"
  require_linux_root "$manager"

  if is_running "$name"; then
    cmd_stop "$name" || true
  fi

  case "$manager" in
    openwrt)
      enable_autostart_openwrt "$name" "$runner"
      ;;
    systemd)
      enable_autostart_systemd "$name" "$runner"
      ;;
    launchd)
      enable_autostart_launchd "$name" "$runner"
      ;;
    cron)
      enable_autostart_cron "$name" "$runner"
      cmd_start "$name"
      ;;
    *)
      err "autostart is not supported on this system"
      exit 1
      ;;
  esac

  log "autostart enabled for '$name' via $manager"
}

cmd_disable_autostart() {
  name="$1"
  manager="$(detect_service_manager)"
  require_linux_root "$manager"
  case "$manager" in
    openwrt)
      disable_autostart_openwrt "$name"
      ;;
    systemd)
      disable_autostart_systemd "$name"
      ;;
    launchd)
      disable_autostart_launchd "$name"
      ;;
    cron)
      disable_autostart_cron "$name"
      ;;
    *)
      ;;
  esac
  rm -f "$(runner_file "$name")"
  log "autostart disabled for '$name'"
}

# Query GitHub releases API for the latest agent tag (e.g. "agent-v0.2.0").
# Returns empty string on failure — callers must handle this gracefully.
get_latest_remote_tag() {
  repo="${1:-$AGENT_REPO}"
  api_url="https://api.github.com/repos/${repo}/releases/latest"
  tag=""
  if command -v curl >/dev/null 2>&1; then
    tag="$(curl -fsSL "$api_url" 2>/dev/null | awk -F'"' '/"tag_name"/{print $4; exit}')"
  elif command -v wget >/dev/null 2>&1; then
    tag="$(wget -qO- "$api_url" 2>/dev/null | awk -F'"' '/"tag_name"/{print $4; exit}')"
  fi
  printf '%s\n' "$tag"
}

# Return the version string reported by the local neko-agent binary, or "".
get_local_binary_version() {
  if [ -x "$AGENT_BIN" ]; then
    "$AGENT_BIN" --version 2>/dev/null | head -1 || true
  fi
}

is_version_arg() {
  v="${1:-}"
  case "$v" in
    ""|latest|agent-v*|v[0-9]*|[0-9]*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

normalize_version_tag() {
  version_arg="${1:-latest}"
  if [ "$version_arg" = "latest" ]; then
    printf 'latest\n'
    return 0
  fi
  case "$version_arg" in
    agent-v*)
      printf '%s\n' "$version_arg"
      ;;
    v*)
      printf 'agent-%s\n' "$version_arg"
      ;;
    *)
      printf 'agent-v%s\n' "$version_arg"
      ;;
  esac
}

target_plain_from_tag() {
  tag="$1"
  printf '%s\n' "${tag#agent-v}"
}

# ── Update / download binary ────────────────────────────────────────────────

# Download, verify, and install a new neko-agent binary.
# Usage: do_download_binary <version_arg> <os> <arch>
#   version_arg: "latest" or "agent-v0.2.0" style tag
do_download_binary() {
  version_arg="$1"
  os="$2"
  arch="$3"

  if [ "$version_arg" = "latest" ]; then
    release_path="releases/latest/download"
    asset="neko-agent_${os}_${arch}.tar.gz"
  else
    # normalise: accept bare "0.2.0" or full "agent-v0.2.0"
    case "$version_arg" in
      agent-v*) tag="$version_arg" ;;
      v*)       tag="agent-${version_arg}" ;;
      *)        tag="agent-v${version_arg}" ;;
    esac
    release_path="releases/download/${tag}"
    asset="neko-agent_${tag}_${os}_${arch}.tar.gz"
  fi

  package_url="https://github.com/${AGENT_REPO}/${release_path}/${asset}"
  checksums_url="https://github.com/${AGENT_REPO}/${release_path}/checksums.txt"

  tmp_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$tmp_dir'" EXIT INT TERM

  archive_path="$tmp_dir/neko-agent.tar.gz"
  checksums_path="$tmp_dir/checksums.txt"

  log "downloading $package_url"
  download_file "$package_url" "$archive_path"

  log "verifying checksum..."
  download_file "$checksums_url" "$checksums_path"
  expected_hash="$(awk -v a="$asset" '$2 == a {print $1}' "$checksums_path" | head -n 1)"
  if [ -z "$expected_hash" ]; then
    err "cannot find checksum for $asset in checksums.txt"
    exit 1
  fi
  actual_hash="$(compute_sha256 "$archive_path")"
  if [ -z "$actual_hash" ]; then
    err "no sha256 tooling found (sha256sum / shasum / openssl)"
    exit 1
  fi
  if [ "$expected_hash" != "$actual_hash" ]; then
    err "checksum mismatch for $asset"
    err "  expected: $expected_hash"
    err "  actual:   $actual_hash"
    exit 1
  fi

  mkdir -p "$tmp_dir/extract"
  tar -xzf "$archive_path" -C "$tmp_dir/extract"

  new_binary="$tmp_dir/extract/neko-agent"
  if [ ! -f "$new_binary" ]; then
    err "extracted archive does not contain neko-agent"
    exit 1
  fi

  chmod +x "$new_binary"
  install_dir="$(dirname "$AGENT_BIN")"
  mkdir -p "$install_dir"
  mv "$new_binary" "$AGENT_BIN"
  log "binary installed: $AGENT_BIN"
}

# Download and install the manager script itself.
# Usage: do_download_manager <agent-tag>
#   agent-tag: e.g. "agent-v0.2.0"
do_download_manager() {
  tag="$1"
  manager_url="https://raw.githubusercontent.com/${AGENT_REPO}/${tag}/apps/agent/nekoagent"

  tmp_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$tmp_dir'" EXIT INT TERM
  new_manager="$tmp_dir/nekoagent"

  log "downloading manager script: $manager_url"
  download_file "$manager_url" "$new_manager"
  chmod +x "$new_manager"

  mkdir -p "$INSTALL_DIR"
  manager_target="$INSTALL_DIR/nekoagent"
  mv "$new_manager" "$manager_target"
  log "manager installed: $manager_target"

  current_path="$(command -v "$PROG" 2>/dev/null || true)"
  if [ -n "$current_path" ] && [ "$current_path" != "$manager_target" ] && [ -w "$current_path" ]; then
    if [ -e "$current_path" ] && [ -e "$manager_target" ] && [ "$current_path" -ef "$manager_target" ]; then
      log "manager path already points to installed target: $current_path"
    else
      cp "$manager_target" "$current_path"
      chmod +x "$current_path" || true
      log "manager synced to: $current_path"
    fi
  fi
}

# ── Commands ────────────────────────────────────────────────────────────────

version() {
  manager_ver="$VERSION"
  binary_ver="$(get_local_binary_version)"
  if [ -z "$binary_ver" ]; then
    binary_ver="(binary not found)"
  fi
  printf 'nekoagent  %s\n' "$manager_ver"
  printf 'neko-agent %s\n' "$binary_ver"
}

usage() {
  cat <<EOF
Neko Agent Manager v${VERSION}

Usage:
  $PROG init <name> [KEY=VALUE ...]          Create/overwrite config file
  $PROG add <name> [flags/options]           Quick add new backend instance
