require_config_key() {
  key="$1"
  eval "val=\${$key:-}"
  if [ -z "$val" ]; then
    err "missing required key in config: $key"
    exit 1
  fi
}

load_config() {
  name="$1"
  cf="$(config_file "$name")"
  if [ ! -f "$cf" ]; then
    err "config not found: $cf"
    exit 1
  fi
  # shellcheck disable=SC1090
  . "$cf"
  require_config_key "NEKO_SERVER"
  require_config_key "NEKO_BACKEND_ID"
  require_config_key "NEKO_BACKEND_TOKEN"
  require_config_key "NEKO_GATEWAY_TYPE"
  require_config_key "NEKO_GATEWAY_URL"
}

build_agent_args() {
  set -- \
    --server-url "$NEKO_SERVER" \
    --backend-id "$NEKO_BACKEND_ID" \
    --backend-token "$NEKO_BACKEND_TOKEN" \
    --gateway-type "$NEKO_GATEWAY_TYPE" \
    --gateway-url "$NEKO_GATEWAY_URL"

  if [ -n "${NEKO_GATEWAY_TOKEN:-}" ]; then
    set -- "$@" --gateway-token "$NEKO_GATEWAY_TOKEN"
  fi
  if [ -n "${NEKO_AGENT_ID:-}" ]; then
    set -- "$@" --agent-id "$NEKO_AGENT_ID"
  fi
  if [ -n "${NEKO_REPORT_INTERVAL:-}" ]; then
    set -- "$@" --report-interval "$NEKO_REPORT_INTERVAL"
  fi
  if [ -n "${NEKO_HEARTBEAT_INTERVAL:-}" ]; then
    set -- "$@" --heartbeat-interval "$NEKO_HEARTBEAT_INTERVAL"
  fi
  if [ -n "${NEKO_GATEWAY_POLL_INTERVAL:-}" ]; then
    set -- "$@" --gateway-poll-interval "$NEKO_GATEWAY_POLL_INTERVAL"
  fi
  if [ -n "${NEKO_REQUEST_TIMEOUT:-}" ]; then
    set -- "$@" --request-timeout "$NEKO_REQUEST_TIMEOUT"
  fi
  if [ -n "${NEKO_REPORT_BATCH_SIZE:-}" ]; then
    set -- "$@" --report-batch-size "$NEKO_REPORT_BATCH_SIZE"
  fi
  if [ -n "${NEKO_MAX_PENDING_UPDATES:-}" ]; then
    set -- "$@" --max-pending-updates "$NEKO_MAX_PENDING_UPDATES"
  fi
  if [ -n "${NEKO_STALE_FLOW_TIMEOUT:-}" ]; then
    set -- "$@" --stale-flow-timeout "$NEKO_STALE_FLOW_TIMEOUT"
  fi

  log_enabled="${NEKO_LOG:-true}"
  set -- "$@" --log="$log_enabled"

  printf '%s\n' "$*"
}

cmd_init() {
  name="$1"
  shift
  ensure_dirs
  cf="$(config_file "$name")"
  umask 077
  : > "$cf"
  for kv in "$@"; do
    case "$kv" in
      *=*) printf '%s\n' "$kv" >> "$cf" ;;
      *)
        err "invalid key=value pair: $kv"
        exit 1
        ;;
    esac
  done
  log "config written: $cf"
}

# Quick add with flags instead of KEY=VALUE pairs
cmd_add() {
  if [ "$#" -lt 6 ]; then
    err "add requires: <name> --server-url <url> --backend-id <id> --backend-token <token> --gateway-type <type> --gateway-url <url>"
    echo ""
    echo "Usage: $PROG add <name> --server-url <url> --backend-id <id> --backend-token <token> --gateway-type <clash|surge> --gateway-url <url> [--gateway-token <token>] [--auto-start]"
    exit 1
  fi

  name="$1"
  shift

  # Parse flags
  server_url=""
  backend_id=""
  backend_token=""
  gateway_type=""
  gateway_url=""
  gateway_token=""
  auto_start="true"   # default: start immediately after add

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --server-url)
        server_url="$2"
        shift 2
        ;;
      --backend-id)
        backend_id="$2"
        shift 2
        ;;
      --backend-token)
        backend_token="$2"
        shift 2
        ;;
      --gateway-type)
        gateway_type="$2"
        shift 2
        ;;
      --gateway-url)
        gateway_url="$2"
        shift 2
        ;;
      --gateway-token)
        gateway_token="$2"
        shift 2
        ;;
      --auto-start)
        auto_start="true"
        shift
        ;;
      --no-start)
        auto_start="false"
        shift
        ;;
      *)
        err "unknown flag: $1"
        exit 1
        ;;
    esac
  done

  # Validate required fields
  if [ -z "$server_url" ] || [ -z "$backend_id" ] || [ -z "$backend_token" ] || [ -z "$gateway_type" ] || [ -z "$gateway_url" ]; then
    err "missing required flags"
    echo "Required: --server-url, --backend-id, --backend-token, --gateway-type, --gateway-url"
    exit 1
  fi

  # Build config
  config_vars=""
  config_vars="$config_vars NEKO_SERVER=$server_url"
  config_vars="$config_vars NEKO_BACKEND_ID=$backend_id"
  config_vars="$config_vars NEKO_BACKEND_TOKEN=$backend_token"
  config_vars="$config_vars NEKO_GATEWAY_TYPE=$gateway_type"
  config_vars="$config_vars NEKO_GATEWAY_URL=$gateway_url"
  if [ -n "$gateway_token" ]; then
    config_vars="$config_vars NEKO_GATEWAY_TOKEN=$gateway_token"
  fi

  # Initialize config
  cf="$(config_file "$name")"
  if [ -f "$cf" ]; then
    log "updating existing instance '$name' config"
    if is_running "$name"; then
      log "stopping existing instance '$name' before reconfiguring..."
      cmd_stop "$name" || true
    fi
  fi
  # shellcheck disable=SC2086
  cmd_init "$name" $config_vars

  log "instance '$name' added successfully"

  # Auto-start if requested
  if [ "$auto_start" = "true" ]; then
    cmd_start "$name"
  fi
}

cmd_start() {
  name="$1"
  ensure_dirs

  # If managed by service manager, delegate to it
  if is_service_managed "$name"; then
    manager="$(detect_service_manager)"
    service="$(service_name_for_instance "$name")"
    case "$manager" in
      systemd)  systemctl start "$service" ;;
      launchd)
        label="io.neko-master.agent.${name}"
        plist_path="${HOME}/Library/LaunchAgents/${label}.plist"
        launchctl load "$plist_path" 2>/dev/null || true
        ;;
      openwrt)  "/etc/init.d/${service}" start ;;
    esac
    log "instance '$name' started via $manager"
    return 0
  fi

  if [ ! -x "$AGENT_BIN" ]; then
    err "agent binary not found/executable: $AGENT_BIN"
    exit 1
  fi
  if is_running "$name"; then
    log "instance '$name' already running (pid $(cat "$(pid_file "$name")"))"
    return 0
  fi

  load_config "$name"
  args="$(build_agent_args)"
  lf="$(log_file "$name")"
  pf="$(pid_file "$name")"

  # shellcheck disable=SC2086
  nohup "$AGENT_BIN" $args >> "$lf" 2>&1 &
  pid=$!
  printf '%s\n' "$pid" > "$pf"
  log "instance '$name' started, pid=$pid, log=$lf"
}

cmd_stop() {
  name="$1"

  # If managed by service manager, delegate to it
  if is_service_managed "$name"; then
    manager="$(detect_service_manager)"
    service="$(service_name_for_instance "$name")"
    case "$manager" in
      systemd)  systemctl stop "$service" ;;
      launchd)
        label="io.neko-master.agent.${name}"
        plist_path="${HOME}/Library/LaunchAgents/${label}.plist"
        launchctl unload "$plist_path" 2>/dev/null || true
        ;;
      openwrt)  "/etc/init.d/${service}" stop ;;
    esac
    rm -f "$(pid_file "$name")"
    log "instance '$name' stopped via $manager"
    return 0
  fi

  pf="$(pid_file "$name")"
  if ! is_running "$name"; then
    rm -f "$pf"
    log "instance '$name' is not running"
    return 0
  fi
  pid="$(cat "$pf")"
  kill "$pid" >/dev/null 2>&1 || true
  # Wait up to 12s for graceful shutdown (agent needs up to 10s for final flush)
  i=0
  while [ "$i" -lt 12 ] && kill -0 "$pid" >/dev/null 2>&1; do
    sleep 1
    i=$((i + 1))
  done
  if kill -0 "$pid" >/dev/null 2>&1; then
    kill -9 "$pid" >/dev/null 2>&1 || true
  fi
  rm -f "$pf"
  log "instance '$name' stopped"
}

cmd_status() {
  name="$1"
  managed=""
  if is_service_managed "$name"; then
    managed=" (managed by $(detect_service_manager))"
  fi
  if is_running "$name"; then
    pid=""
    if is_service_managed "$name"; then
      manager="$(detect_service_manager)"
      service="$(service_name_for_instance "$name")"
      case "$manager" in
        systemd)
          pid="$(systemctl show -p MainPID --value "$service" 2>/dev/null || true)"
          ;;
      esac
    fi
    if [ -z "$pid" ] || [ "$pid" = "0" ]; then
      pf="$(pid_file "$name")"
      [ -f "$pf" ] && pid="$(cat "$pf" 2>/dev/null || true)"
    fi
    if [ -n "$pid" ] && [ "$pid" != "0" ]; then
      log "instance '$name' is running (pid $pid)${managed}"
    else
      log "instance '$name' is running${managed}"
    fi
    exit 0
  fi
  log "instance '$name' is stopped${managed}"
  exit 1
}

cmd_logs() {
  name="$1"

  # Service-managed instances don't write the wrapper's $lf; route to the
  # appropriate native log source instead.
  if is_service_managed "$name"; then
    manager="$(detect_service_manager)"
    service="$(service_name_for_instance "$name")"
    case "$manager" in
      systemd)
        journalctl -u "$service" -f --no-pager
        return 0
        ;;
      openwrt)
        # procd_set_param stdout/stderr 1 routes to syslog → logread
        if command -v logread >/dev/null 2>&1; then
          logread -e "$service" -f
          return 0
        fi
        ;;
      launchd)
        # launchd plist writes to $lf directly, fall through to tail
        ;;
    esac
  fi

  lf="$(log_file "$name")"
  if [ ! -f "$lf" ]; then
    err "log file not found: $lf"
    exit 1
  fi
  tail -f "$lf"
}

cmd_list() {
  ensure_dirs
  found=false
  for f in "$CONFIG_DIR"/*.env; do
    if [ ! -e "$f" ]; then
      continue
    fi
    found=true
    name="$(basename "$f" .env)"
    if is_running "$name"; then
      status="running"
    else
      status="stopped"
    fi
    managed=""
    if is_service_managed "$name"; then
      managed=" [$(detect_service_manager)]"
    fi
    # Load config to show backend info
    # shellcheck disable=SC1090
    . "$f"
    printf '%-20s %-10s backend-id=%s gateway=%s%s\n' "$name" "$status" "${NEKO_BACKEND_ID:-?}" "${NEKO_GATEWAY_TYPE:-?}" "$managed"
  done
  if [ "$found" = false ]; then
    log "no instances configured"
  fi
}

cmd_restart_all() {
  ensure_dirs
  restarted_any=false
  for f in "$CONFIG_DIR"/*.env; do
    if [ ! -e "$f" ]; then
      continue
    fi
    name="$(basename "$f" .env)"
    if is_running "$name"; then
      log "restarting '$name'..."
      cmd_stop "$name" || true
      cmd_start "$name"
      restarted_any=true
    fi
  done
  if [ "$restarted_any" = false ]; then
    log "no running instances found"
  fi
}

cmd_upgrade_global() {
  version_arg="${1:-latest}"
  os="$(normalize_os)"
  arch="$(normalize_arch)"

  if [ "$version_arg" = "latest" ]; then
    log "querying GitHub for latest release..."
    target_tag="$(get_latest_remote_tag "$AGENT_REPO")"
    if [ -z "$target_tag" ]; then
      err "failed to determine latest version from GitHub API"
      err "hint: check network access or specify a version: $PROG upgrade agent-v0.2.0"
      exit 1
    fi
  else
    target_tag="$(normalize_version_tag "$version_arg")"
  fi
  target_plain="$(target_plain_from_tag "$target_tag")"

  local_version="$(get_local_binary_version)"
  binary_changed=false
  if [ -n "$local_version" ] && [ "$local_version" = "$target_plain" ]; then
    log "binary already at $local_version, no binary download needed"
  else
    log "upgrading binary: ${local_version:-not installed} -> $target_plain"
    do_download_binary "$target_tag" "$os" "$arch"
    binary_changed=true
  fi

  do_download_manager "$target_tag"

  restarted_any=false
  for f in "$CONFIG_DIR"/*.env; do
    if [ ! -e "$f" ]; then
      continue
    fi
    name="$(basename "$f" .env)"
    if is_running "$name"; then
      log "restarting running instance '$name'..."
      if is_service_managed "$name"; then
        # Re-generate runner script and update service unit for managed instances
        load_config "$name"
        runner="$(generate_runner_script "$name")"
        manager="$(detect_service_manager)"
        service="$(service_name_for_instance "$name")"
        case "$manager" in
          systemd)
            write_systemd_unit "$name" "$runner" >/dev/null
            systemctl daemon-reload
            systemctl restart "$service"
            ;;
          launchd)
            plist_path="$(write_launchd_plist "$name" "$runner")"
            launchctl unload "$plist_path" >/dev/null 2>&1 || true
            launchctl load "$plist_path"
            ;;
          openwrt)
            write_openwrt_init "$name" "$runner" >/dev/null
            "/etc/init.d/${service}" restart
            ;;
        esac
      else
        cmd_stop "$name" || true
        cmd_start "$name"
      fi
      restarted_any=true
    fi
  done

  if [ "$restarted_any" = false ]; then
    log "no running instances found; binary upgraded globally"
  fi

  log "upgrade complete: manager + binary at version $target_plain"
}

cmd_remove() {
  name="$1"

  cmd_disable_autostart "$name" >/dev/null 2>&1 || true

  if is_running "$name"; then
    cmd_stop "$name"
  fi

  rm -f "$(pid_file "$name")"
  rm -f "$(log_file "$name")"
  rm -f "$(runner_file "$name")"

  cf="$(config_file "$name")"
  if [ -f "$cf" ]; then
    rm -f "$cf"
  fi

  log "instance '$name' removed"
}

cmd_uninstall() {
  rm -f "$AGENT_BIN"
  rm -f "$INSTALL_DIR/nekoagent"
  rm -f "/usr/local/bin/neko-agent" "/usr/local/bin/nekoagent"
  log "binaries removed"
  log "note: instance config files remain in $CONFIG_DIR (use '$PROG remove <name>' if needed)"
}

main() {
  if [ "$#" -lt 1 ]; then
    usage
    exit 1
  fi

  cmd="$1"
  shift

  case "$cmd" in
    init)
      if [ "$#" -lt 2 ]; then
        usage
        exit 1
      fi
      cmd_init "$@"
      ;;
    add)
      if [ "$#" -lt 6 ]; then
        usage
        exit 1
      fi
      cmd_add "$@"
      ;;
    start|stop|restart|status|logs|enable-autostart|disable-autostart)
      if [ "$#" -ne 1 ]; then
        usage
        exit 1
      fi
      case "$cmd" in
        start)   cmd_start "$1" ;;
        stop)    cmd_stop "$1" ;;
        restart) cmd_stop "$1" || true; cmd_start "$1" ;;
        status)  cmd_status "$1" ;;
        logs)    cmd_logs "$1" ;;
        enable-autostart) cmd_enable_autostart "$1" ;;
        disable-autostart) cmd_disable_autostart "$1" ;;
      esac
      ;;
    upgrade)
      if [ "$#" -gt 1 ]; then
        usage
        exit 1
      fi
      if [ "$#" -eq 1 ] && ! is_version_arg "$1"; then
        err "upgrade only accepts an optional version (e.g. agent-v0.2.0), not instance name"
        exit 1
      fi
      cmd_upgrade_global "${1:-latest}"
      ;;
    update)
      err "'update' command has been removed; use '$PROG upgrade [version]'"
      exit 1
      ;;
    remove|delete)
      if [ "$#" -ne 1 ]; then
        usage
        exit 1
      fi
      cmd_remove "$1"
      ;;
    uninstall)
      if [ "$#" -ne 0 ]; then
        err "uninstall does not accept instance name; use '$PROG remove <name>'"
        usage
        exit 1
      fi
      cmd_uninstall
      ;;
    list)
      cmd_list
      ;;
    restart-all)
      cmd_restart_all
      ;;
    version|-v|--version)
      version
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
